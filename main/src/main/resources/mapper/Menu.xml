<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.main.mapper.MenuMapper">
    <select id="getMenus" resultType="com.example.main.dto.MenuDTO">
        SELECT ID
               , CATEGORY
               , NAME
               , ICON
               , COLOR
               , IDX
               , CREATE_DATE 
          FROM TB_MENU
         WHERE 1=1
        <if test="category != null and category != ''">
           AND category LIKE #{category}
        </if>
         ORDER BY IDX ASC
    </select>
</mapper>
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.main.mapper.MemberMapper">
    <select id="getMembers" resultType="com.example.main.dto.MemberDTO">
        SELECT ID
               , NAME
               , PASSWORD
               , EMAIL
               , CREATE_DATE
          FROM TB_MEMBER
         ORDER BY CREATE_DATE ASC
    </select>
</mapper>